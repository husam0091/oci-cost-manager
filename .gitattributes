# Force LF line endings for shell scripts — prevents CRLF breakage on Windows clones
*.sh        text eol=lf
*.py        text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.conf      text eol=lf
*.ini       text eol=lf
*.toml      text eol=lf
*.txt       text eol=lf
*.sql       text eol=lf
Dockerfile  text eol=lf
.gitignore  text eol=lf
.env*       text eol=lf

# Binaries — do not modify
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.pem       binary
*.key       binary
*.p12       binary
*.pfx       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
