# Database and pooling
DATABASE_URL=postgresql+psycopg://user:pass@pgbouncer:6432/ocicost

# Cache and worker
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# OCI configuration
OCI_CONFIG_PROFILE=DEFAULT
OCI_CONFIG_PATH=/home/app/.oci/config

# Security — both keys are auto-generated on first start and persisted to the
# app_data volume. You only need to set these explicitly when migrating data
# from an existing installation.
# APP_SECRET=                 # JWT signing key (auto-generated)
# APP_MASTER_KEY=             # Encryption master key (auto-generated)
