# OCI Cost Manager - Environment Configuration

# Application Settings
DEBUG=true
APP_NAME="OCI Cost Manager"
APP_VERSION="1.0.0"

# API Settings
API_PREFIX=/api/v1

# Database
# SQLite (development)
DATABASE_URL=sqlite:///./oci_cost_manager.db
# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/oci_cost_manager

# OCI Configuration
OCI_CONFIG_FILE=~/.oci/config
OCI_CONFIG_PROFILE=DEFAULT

# OCI Price List API
OCI_PRICE_API_URL=https://apexapps.oracle.com/pls/apex/cetools/api/v1/products/

# Cache TTL (seconds)
CACHE_TTL_COMPARTMENTS=3600
CACHE_TTL_RESOURCES=900
CACHE_TTL_PRICES=86400

# CORS Origins (JSON array)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
